# Supabase (supabase start 출력값 / 호스팅 프로젝트 값)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 앱 (Origin 검증·cron 킥 대상)
APP_URL=http://localhost:3000

# 워커 내부 인증 (pg_cron → /api/jobs/* 헤더 x-cron-secret)
CRON_SECRET=

# AI (DESIGN §6.4 — 교체 노브 3개)
GOOGLE_GENERATIVE_AI_API_KEY=
AI_ENRICH_MODEL=gemini-flash-latest
AI_EMBED_MODEL=gemini-embedding-001
AI_EMBED_DIM=1536

# 선택: 유튜브 자막 서버 폴백용 프록시 (§5.4)
# CAPTION_PROXY_URL=
